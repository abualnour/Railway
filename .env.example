DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_PUBLIC_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nouraxis_local
DJANGO_MEDIA_ROOT=media
DJANGO_MEDIA_URL=/media/
# Optional platform volume paths:
# RAILWAY_VOLUME_MOUNT_PATH=/data
# Optional backup override:
# HR_BACKUP_ROOT=/data/backups
# Or use these instead of DATABASE_URL:
# POSTGRES_DB=nouraxis_local
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
